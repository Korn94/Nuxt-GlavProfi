// tsconfig.json
{
  "extends": "./.nuxt/tsconfig.json",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.vue",
    "stores/**/*.ts"
  ],
  "exclude": ["node_modules", ".nuxt", "dist", ".git", ".output"],
  "compilerOptions": {
    "types": ["nuxt", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "~~/*": ["./"],
      "@@/*": ["./"],
    }
  }
}
